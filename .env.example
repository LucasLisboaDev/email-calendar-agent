# ─── Google OAuth ───────────────────────────────────────────
# Path to your downloaded credentials.json from Google Cloud
GOOGLE_CREDENTIALS_PATH=credentials.json

# Path where the OAuth token will be saved after first login
GOOGLE_TOKEN_PATH=token.json

# ─── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Gmail settings ─────────────────────────────────────────
# How many emails to fetch per run
EMAIL_FETCH_LIMIT=10

# Gmail label to watch (INBOX, UNREAD, or a custom label)
EMAIL_LABEL=INBOX

# ─── Agent settings ─────────────────────────────────────────
# Require human approval before sending emails or booking meetings
HUMAN_APPROVAL_REQUIRED=true

# ─── App ─────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
